# AquaGuard — Ortam Değişkenleri
# Bu dosyayı `.env.local` olarak kopyalayın ve değerleri doldurun.

# JWT Secret — production'da güçlü bir anahtar kullanın
JWT_SECRET=your-secret-key-change-in-production

# Resend API Key — 'mock' yazarsanız e-postalar konsola yazdırılır
# Gerçek key: https://resend.com/api-keys
RESEND_API_KEY=mock

# Google Gemini API Key — 'mock' yazarsanız yerel fallback yanıtlar kullanılır
# Gerçek key: https://aistudio.google.com/apikey
GEMINI_API_KEY=mock

# Uygulama URL'si
NEXT_PUBLIC_APP_URL=http://localhost:3000
